{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithEnvironmentName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/logs/Gateway.API/log-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "Ims.DemoPlatform.Gateway.API"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-health": {
        "ClusterId": "identityCluster",
        "Match": { "Path": "/identity/health" },
        "Transforms": [ { "PathRemovePrefix": "/identity" } ]
      },
      "notifications-health": {
        "ClusterId": "notificationsCluster",
        "Match": { "Path": "/notifications/health" },
        "Transforms": [ { "PathRemovePrefix": "/notifications" } ]
      },
      "projects-health": {
        "ClusterId": "projectsCluster",
        "Match": { "Path": "/projects/health" },
        "Transforms": [ { "PathRemovePrefix": "/projects" } ]
      },
      "tasks-health": {
        "ClusterId": "tasksCluster",
        "Match": { "Path": "/tasks/health" },
        "Transforms": [ { "PathRemovePrefix": "/tasks" } ]
      },
      "identity": {
        "ClusterId": "identityCluster",
        "Match": { "Path": "/identity/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/identity" } ],
        "RateLimiterPolicy": "auth"
      },
      "notifications": {
        "ClusterId": "notificationsCluster",
        "Match": { "Path": "/notifications/{**catch-all}" }
      },
      "projects": {
        "ClusterId": "projectsCluster",
        "Match": { "Path": "/projects/{**catch-all}" }
      },
      "tasks": {
        "ClusterId": "tasksCluster",
        "Match": { "Path": "/tasks/{**catch-all}" }
      }
    },
    "Clusters": {
      "identityCluster": {
        "Destinations": {
          "identity": { "Address": "http://identity:8080/" }
        },
        "HealthCheck": {
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate", "ReactivationPeriod": "00:00:30" }
        }
      },
      "notificationsCluster": {
        "Destinations": {
          "notifications": { "Address": "http://notifications:8080/" }
        },
        "HealthCheck": {
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate", "ReactivationPeriod": "00:00:30" }
        }
      },
      "projectsCluster": {
        "Destinations": {
          "projects": { "Address": "http://projects:8080/" }
        },
        "HealthCheck": {
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate", "ReactivationPeriod": "00:00:30" }
        }
      },
      "tasksCluster": {
        "Destinations": {
          "tasks": { "Address": "http://tasks:8080/" }
        },
        "HealthCheck": {
          "Passive": { "Enabled": true, "Policy": "TransportFailureRate", "ReactivationPeriod": "00:00:30" }
        }
      }
    }
  }
}
