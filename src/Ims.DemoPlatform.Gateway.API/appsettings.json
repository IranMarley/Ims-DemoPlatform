{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-health": {
        "ClusterId": "identityCluster",
        "Match": { "Path": "/identity/health" },
        "Transforms": [ { "PathRemovePrefix": "/identity" } ]
      },
      "notifications-health": {
        "ClusterId": "notificationsCluster",
        "Match": { "Path": "/notifications/health" },
        "Transforms": [ { "PathRemovePrefix": "/notifications" } ]
      },
      "projects-health": {
        "ClusterId": "projectsCluster",
        "Match": { "Path": "/projects/health" },
        "Transforms": [ { "PathRemovePrefix": "/projects" } ]
      },
      "tasks-health": {
        "ClusterId": "tasksCluster",
        "Match": { "Path": "/tasks/health" },
        "Transforms": [ { "PathRemovePrefix": "/tasks" } ]
      },
      "identity": {
        "ClusterId": "identityCluster",
        "Match": { "Path": "/identity/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/identity" } ]
      },
      "notifications": {
        "ClusterId": "notificationsCluster",
        "Match": { "Path": "/notifications/{**catch-all}" }
      },
      "projects": {
        "ClusterId": "projectsCluster",
        "Match": { "Path": "/projects/{**catch-all}" }
      },
      "tasks": {
        "ClusterId": "tasksCluster",
        "Match": { "Path": "/tasks/{**catch-all}" }
      }
    },
    "Clusters": {
      "identityCluster": {
        "Destinations": {
          "identity": { "Address": "http://identity:8080/" }
        }
      },
      "notificationsCluster": {
        "Destinations": {
          "notifications": { "Address": "http://notifications:8080/" }
        }
      },
      "projectsCluster": {
        "Destinations": {
          "projects": { "Address": "http://projects:8080/" }
        }
      },
      "tasksCluster": {
        "Destinations": {
          "tasks": { "Address": "http://tasks:8080/" }
        }
      }
    }
  }
}
